<div
  id="searchModal"
  class="search-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Search posts"
  aria-hidden="true"
  data-baseurl="{{ site.baseurl }}"
>
  <div class="search-modal__backdrop" id="searchModalBackdrop"></div>
  <div class="search-modal__dialog" id="searchModalDialog">
    <div class="search-modal__header">
      <label for="searchModalInput" class="search-modal__label">Search posts</label>
      <input
        type="search"
        id="searchModalInput"
        class="search-modal__input"
        autocomplete="off"
        aria-label="Search in posts"
        placeholder="Search…"
      />
      <button type="button" class="search-modal__close" id="searchModalClose" aria-label="Close search">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="search-modal__results" id="searchModalResults">
      <p class="search-modal__placeholder" id="searchModalPlaceholder" data-placeholder="Type to search posts…">Type to search posts…</p>
    </div>
  </div>
</div>
